<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp">

    <TextView
        android:id="@+id/tv_help_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Centro de Ayuda"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_help_desc"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Si tienes algún problema técnico o duda sobre tu cuenta, nuestro equipo de soporte está disponible para atenderte por teléfono."
        android:textColor="#BBBBBB"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_help_title" />

    <Button
        android:id="@+id/btn_call_support"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:backgroundTint="#448AFF"
        android:drawableStart="@android:drawable/ic_menu_call"
        android:padding="12dp"
        android:text="Llamar a Soporte"
        android:textColor="#FFFFFF"
        app:layout_constraintTop_toBottomOf="@id/tv_help_desc" />

</androidx.constraintlayout.widget.ConstraintLayout>